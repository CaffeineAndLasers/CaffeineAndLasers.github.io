---
title: Default Title
css: /styles.css
nesting: ../../
---

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <head><title>{{ title }}</title></head>
    <link href="{{ nesting }}Assets/favicon.ico" rel="icon" type="image/x-icon" />
    <link rel="stylesheet" href="{{css}}">
</head>

{% include "header.liquid" %}

<div id="flex">

<aside id="leftSidebar">{% include "sidebar.liquid" %}</aside>

<main>
{{ content }}

<p>
QR Code!
</p>

<div class="qr-code-container">
  {{ qrCode(page.url, "Scan this QR code to share this blog post") }}
</div>


<div id="c_widget"></div>
<script src="{{nesting}}comment-widget/comment-widget.js"></script>
</main>

</div>
{% include "footer.liquid" %}

</html>
